    <div>
        <img src="webdev.jpg">
        <h3>Web Development</h3>
        <p>HTML, CSS, JavaScript</p>
        <progress value="80" max="100"></progress>
    </div>

    <!-- Python -->
    <div>
        <img src="python.jfif">
        <h3>Python Programming</h3>
        <p>Beginner to Advanced</p>
        <progress value="55" max="100"></progress>
    </div>

    <!-- Data Structures -->
    <div>
        <img src="datastr.jfif">
        <h3>Data Structures</h3>
        <p>Core Concepts</p>
        <progress value="30" max="100"></progress>
    </div>  

    <hr>

    <!-- Deadlines -->
    <h2>Upcoming Deadlines</h2>
    <ul>
        <li>HTML Project - 28 March</li>
        <li>Python Assignment - 30 March</li>
        <li>DSA Quiz - 2 April</li>
    </ul>

    <hr>

    <!-- Video Section -->
    <h2>Video Lecture</h2>

    <iframe width="400" height="250" src="https://www.youtube.com/embed/HD13eq_Pmp8" title="HTML Tutorial"
