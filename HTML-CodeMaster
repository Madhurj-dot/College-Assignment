<!DOCTYPE html>
<html>

<head>
    <title>CodeMaster Academy Dashboard</title>
    <style>
        img {
            width: 250px;
            height: 150px;
            transition: 0.3s;
        }

        img:hover {
            transform: scale(1.1);
            border: 2px solid blue;
        }
    </style>
</head>

<body style="
background: linear-gradient(to right, black, navy);
background-image: radial-gradient(gray 1px, transparent 1px), 
