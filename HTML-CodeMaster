background-size: 20px 20px, 100% 100%;
color: white;
font-family: Arial;
">
    <h1 align="center">CodeMaster Academy</h1>
    <h2 align="center">Student Dashboard</h2>


    <hr>

    <!-- Courses Section -->
    <h2>Enrolled Courses</h2>

